<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="tests/bootstrap.php"
    colors="true"
    testdox="true"
    cacheDirectory=".phpunit.cache"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
    </testsuites>

    <!-- Files tracked for code coverage (use the coverage-text flag to report). -->
    <source>
        <include>
            <file>dc-sw-prefetch.php</file>
            <file>includes/integrations.php</file>
            <file>admin.php</file>
        </include>
    </source>
</phpunit>
