<?xml version="1.0"?>
<ruleset name="DC Script Worker Proxy">
    <description>PHPCS rules for DC Script Worker Proxy plugin.</description>

    <file>.</file>
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>
    <arg value="sp"/>
    <arg name="extensions" value="php"/>

    <rule ref="WordPress">
    </rule>

    <!-- Declare the plugin's text domain so i18n sniffs don't flag it as a mismatch -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="dc-script-worker-prefetcher"/>
            </property>
        </properties>
    </rule>

    <!-- Declare plugin prefix so NamingConventions don't flag dc_swp_ functions -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="dc_swp"/>
                <element value="DC_SWP"/>
            </property>
        </properties>
    </rule>
</ruleset>
